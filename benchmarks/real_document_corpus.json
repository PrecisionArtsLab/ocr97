      "source_note": "Public sample vendor invoice from NYU ISAW.",
      "required_tokens": ["Vendor Name", "INVOICE #", "Laundry Service", "TOTAL", "$ 567.50"],
      "expected_table_rows": 0,
      "expected_fields": [
        {"name": "invoice_number", "aliases": ["INVOICE #"], "expected": "4", "type": "text"},
        {"name": "invoice_date", "aliases": ["DATE"], "expected": "2011-07-08", "type": "date"},
        {"name": "amount", "aliases": ["AMOUNT"], "expected": "462.00", "type": "money"},
        {"name": "total", "aliases": ["TOTAL"], "expected": "567.50", "type": "money"}
      ]
    },
    {
      "id": "irs_w9_2024",
      "label": "IRS Form W-9 March 2024",
      "url": "https://www.irs.gov/pub/irs-pdf/fw9.pdf",
      "filename": "irs_w9_2024.pdf",
      "source_note": "Official IRS W-9 PDF, used for form-token and layout coverage.",
      "required_tokens": ["Form W-9", "Request for Taxpayer", "Identification Number", "Certification", "Internal Revenue Service"],
      "expected_table_rows": 0,
      "expected_fields": [
        {"name": "form_number", "aliases": ["Form"], "expected": "W-9", "type": "text"}
      ]
    }
  ]
